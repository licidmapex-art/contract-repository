NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Netlify: also set these runtime copies (same values) for middleware/edge
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback — prefer Settings → API Keys in the app UI
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_API_KEYS=your-second-key,your-third-key
# GEMINI_MODEL=gemini-2.5-flash
# OCR scanned PDFs on upload when the text layer is empty (set false to disable)
PDF_OCR=true

# Cron jobs (scheduled keep-alive + Gmail poll)
CRON_SECRET=your-cron-secret

# Manual email ingest API
INGEST_SECRET=your-ingest-secret

# Gmail ingestion (optional)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=me
